{
  "name": "revertlens",
  "version": "0.1.0",
  "description": "The only debugger that understands Injective EVM precompiles. Decodes the opaque reverts that Tenderly, Foundry and generic EVM tools cannot see.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "demo": "tsx src/demo.ts",
    "live": "tsx src/live-demo.ts",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:smoke": "tsx src/mcp/smoke.ts",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
