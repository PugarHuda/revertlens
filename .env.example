# Optional. Enables the AI long-tail explainer (src/ai/explain.ts) for reverts
# that have no verified knowledge-base answer. Without any key, RevertLens still
# works fully via the deterministic precompile linter + live on-chain revert
# decoding — it just won't add AI-inferred explanations for the long tail.
# It never fabricates output.

# Provider 1 (free) — OpenRouter. Preferred when set. Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional model override (default: openai/gpt-oss-120b:free). Other good free
# options: z-ai/glm-4.5-air:free, nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL=

# Provider 2 — Anthropic. Used only if OPENROUTER_API_KEY is unset. Model: claude-opus-4-7
ANTHROPIC_API_KEY=

# Public API hardening: the web /api/analyze endpoint does NOT call the AI model
# unless this is set to 1 (prevents anonymous traffic from burning your AI key /
# rate limits). CLI and MCP run the AI long-tail regardless when a key is set.
REVERTLENS_PUBLIC_AI=
